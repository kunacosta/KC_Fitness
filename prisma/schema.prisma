generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ExerciseCategory {
  CHEST
  BACK
  LEGS
  SHOULDERS
  ARMS
  CORE
  FULL_BODY
  CARDIO
  OTHER
}

enum MovementPattern {
  PUSH
  PULL
  SQUAT
  HINGE
  LUNGE
  CARRY
  ROTATION
  ISOLATION
  OTHER
}

enum EquipmentType {
  BARBELL
  DUMBBELL
  MACHINE
  CABLE
  BODYWEIGHT
  KETTLEBELL
  SMITH_MACHINE
  EZ_BAR
  RESISTANCE_BAND
  OTHER
}

enum SetType {
  WARMUP
  WORKING
  TOP_SET
  BACKOFF
  FAILURE
}

/// How a single set is measured — drives the overload algorithm and UI inputs.
enum MeasurementType {
  WEIGHT_REPS    // traditional lifting: weight + reps
  REPS_ONLY      // bodyweight: just reps (push-ups, pull-ups)
  TIME           // duration-based: seconds (plank, dead hang)
  DISTANCE_TIME  // cardio: distance (km) + duration (seconds)
  WEIGHT_TIME    // weighted holds: weight + duration (farmer's carry)
}

enum SuggestionType {
  INCREASE_WEIGHT
  INCREASE_REPS
  INCREASE_DURATION
  INCREASE_DISTANCE
  IMPROVE_PACE
  HOLD
  DELOAD
}

model User {
  id               String            @id @default(cuid())
  email            String?           @unique
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  exercises        Exercise[]
  workoutSessions  WorkoutSession[]
  progressionLogs  ProgressionSnapshot[]
}

model Exercise {
  id                    String                 @id @default(cuid())
  userId                String?
  user                  User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String
  slug                  String
  category              ExerciseCategory       @default(OTHER)
  movementPattern       MovementPattern        @default(OTHER)
  equipment             EquipmentType          @default(OTHER)
  primaryMuscle         String?
  secondaryMuscles      String?
  notes                 String?
  isCustom              Boolean                @default(true)
  measurementType       MeasurementType        @default(WEIGHT_REPS)
  // WEIGHT_REPS / WEIGHT_TIME / REPS_ONLY progression settings
  incrementStep         Decimal                @default(2.5)
  repTargetMin          Int                    @default(6)
  repTargetMax          Int                    @default(10)
  targetRirMin          Decimal?               @default(0)
  targetRirMax          Decimal?               @default(2)
  // TIME / WEIGHT_TIME settings
  durationTargetSeconds Int?
  // DISTANCE_TIME settings
  distanceTargetKm      Decimal?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  workoutExercises      WorkoutExercise[]
  progressionSnapshots  ProgressionSnapshot[]

  @@unique([userId, slug])
  @@index([userId, name])
}

model WorkoutSession {
  id                   String              @id @default(cuid())
  userId               String
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                String
  notes                String?
  performedAt          DateTime            @default(now())
  durationMin          Int?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  workoutExercises     WorkoutExercise[]
  progressionSnapshots ProgressionSnapshot[]

  @@index([userId, performedAt])
}

model WorkoutExercise {
  id               String         @id @default(cuid())
  workoutSessionId String
  exerciseId       String
  orderIndex       Int
  notes            String?
  createdAt        DateTime       @default(now())
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exercise         Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  sets             ExerciseSet[]

  @@index([workoutSessionId, orderIndex])
  @@index([exerciseId])
}

model ExerciseSet {
  id                String          @id @default(cuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  setNumber         Int
  setType           SetType         @default(WORKING)
  // WEIGHT_REPS / WEIGHT_TIME fields
  weight            Decimal         @default(0)
  // WEIGHT_REPS / REPS_ONLY fields
  reps              Int             @default(0)
  // TIME / DISTANCE_TIME / WEIGHT_TIME fields
  durationSeconds   Int?
  // DISTANCE_TIME fields
  distanceKm        Decimal?
  // Quality / intensity fields
  rir               Decimal?
  restSeconds       Int?
  tempo             String?
  completed         Boolean         @default(true)
  createdAt         DateTime        @default(now())

  @@unique([workoutExerciseId, setNumber])
  @@index([workoutExerciseId])
}

model ProgressionSnapshot {
  id                          String          @id @default(cuid())
  userId                      String
  exerciseId                  String
  workoutSessionId            String
  user                        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise                    Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  workoutSession              WorkoutSession  @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  // WEIGHT_REPS / REPS_ONLY metrics
  totalVolume                 Decimal
  effectiveVolume             Decimal
  averageRir                  Decimal?
  bestSetWeight               Decimal?
  bestSetReps                 Int?
  estimated1RM                Decimal?
  // TIME / WEIGHT_TIME metrics
  bestDurationSeconds         Int?
  totalDurationSeconds        Int?
  // DISTANCE_TIME metrics
  bestDistanceKm              Decimal?
  totalDistanceKm             Decimal?
  bestPaceMinPerKm            Decimal?
  // Cross-type delta
  volumeDeltaPct              Decimal?
  performanceScore            Decimal?
  // Suggestion output
  nextSuggestionType          SuggestionType
  nextSuggestedWeight         Decimal?
  nextSuggestedRepMin         Int?
  nextSuggestedRepMax         Int?
  nextSuggestedDurationSeconds Int?
  nextSuggestedDistanceKm     Decimal?
  rationale                   String?
  createdAt                   DateTime       @default(now())

  @@index([exerciseId, createdAt])
  @@index([userId, createdAt])
  @@index([workoutSessionId])
}
